{
  "name": "@kdog3682/node-canvas-experiment",
  "version": "1.0.0",
  "description": "Precomputed font metrics for fast text measurement without a canvas context",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "font-metrics.json"
  ],
  "scripts": {
    "build": "bun build ./index.ts --outdir ./dist --target node && tsc -p tsconfig.json"
  },
  "keywords": [
    "font",
    "metrics",
    "typography",
    "canvas",
    "text-measurement"
  ],
  "license": "MIT"
}
